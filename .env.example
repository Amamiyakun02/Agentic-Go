# mongo db config
MONGO_USER=your_mongo_user
MONGO_PASS=your_mongo_password
MONGO_DB_NAME=PersonalAssistant

# qdrant db config
QDRANT_URL=https://your-qdrant-instance.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# redis db config
REDIS_API_KEY=your_redis_api_key
REDIS_HOST=your-redis-host.redislabs.com
REDIS_PORT=13703
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# supabase config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_BUCKET=aimer_agentic

# Token API Gateway Fonnte untuk notifikasi WhatsApp otomatis
WHATSAPP_GATEWAY_TOKEN=your_whatsapp_gateway_token

# github config
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token

# gemini key
GEMINI_API_KEY=your_gemini_api_key

# jwt & google oauth config
JWT_SECRET=your_super_secret_jwt_key
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# firebase config
FIREBASE_CREDENTIALS_PATH=c:/path/to/your/firebase-key.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# local mcp config
MCP_URL=http://localhost:8000/mcp

# Spotify config
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
